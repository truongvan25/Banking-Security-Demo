<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>SQL Injection Demo</title>
    <style>
        body { font-family: Arial, sans-serif; max-width: 1100px; margin: 30px auto; padding: 0 20px; }
        nav { display: flex; justify-content: space-between; align-items: center;
              background: #2c3e50; color: white; padding: 12px 20px; border-radius: 8px; margin-bottom: 30px; }
        nav a { color: white; text-decoration: none; margin-left: 15px; }
        .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        .card { border-radius: 8px; padding: 20px; }
        .danger { background: #fdf2f2; border: 2px solid #e74c3c; }
        .safe   { background: #f2fdf5; border: 2px solid #27ae60; }
        h3 { margin-top: 0; }
        input { width: 100%; padding: 8px; margin: 6px 0; box-sizing: border-box;
                border: 1px solid #ccc; border-radius: 4px; }
        button { padding: 8px 16px; border: none; border-radius: 4px; cursor: pointer; color: white; }
        .btn-danger { background: #e74c3c; }
        .btn-safe   { background: #27ae60; }
        .query-box { background: #1e1e1e; color: #f8f8f2; padding: 12px;
                     border-radius: 4px; font-family: monospace; font-size: 13px;
                     margin: 10px 0; word-break: break-all; }
        .result-box { background: #f9f9f9; border: 1px solid #ddd; padding: 10px;
                      border-radius: 4px; font-size: 13px; max-height: 200px; overflow-y: auto; }
        .attack-hint { font-size: 12px; color: #888; margin: 4px 0 8px; }
        table { width: 100%; border-collapse: collapse; }
        th, td { padding: 6px 10px; border-bottom: 1px solid #ddd; text-align: left; }
        .section-divider { grid-column: 1 / -1; border-top: 2px dashed #ccc;
                           padding-top: 20px; margin-top: 10px; }
        .badge { display:inline-block; padding: 2px 8px; border-radius: 10px;
                 font-size: 11px; color: white; }
        .ADMIN{background:#e74c3c} .AUDITOR{background:#f39c12} .CUSTOMER{background:#27ae60}
    </style>
</head>
<body>
    <nav>
        <span>SQL Injection Demo</span>
        <div>
            <a href="/" class="btn-blue" style="margin-right:8px">Trang chủ</a>
            <a href="/dashboard">Dashboard</a>
        </div>
    </nav>

    <h2>SQL Injection — Vulnerable vs Secure</h2>

    <!-- LOGIN DEMO -->
    <div class="grid">
        <div class="card danger">
            <h3>❌ Vulnerable Login</h3>
            <p class="attack-hint">Thử payload: <code>admin'#</code> hoặc <code>' OR '1'='1'#</code></p>
            <form method="POST" action="/vulnerable/login">
                <input type="text" name="username" placeholder="Username" value="<%= mode==='login' ? '' : '' %>">
                <input type="text" name="password" placeholder="Password (plain text)">
                <button type="submit" class="btn-danger">Đăng nhập (Không an toàn)</button>
            </form>
        </div>

        <div class="card safe">
            <h3>✅ Secure Login</h3>
            <p class="attack-hint">Cùng payload sẽ không có tác dụng</p>
            <form method="POST" action="/vulnerable/secure-login">
                <input type="text" name="username" placeholder="Username">
                <input type="text" name="password" placeholder="Password (plain text)">
                <button type="submit" class="btn-safe">Đăng nhập (An toàn)</button>
            </form>
        </div>

        <% if (mode === 'login' || mode === 'secure-login') { %>
        <div class="card danger" style="<%= mode==='secure-login' ? 'border-color:#27ae60;background:#f2fdf5' : '' %>">
            <h4>Query thực thi:</h4>
            <div class="query-box"><%= loginQuery %></div>
            <h4>Kết quả:</h4>
            <div class="result-box">
                <% if (typeof loginResult === 'string') { %>
                    <span style="color:red"><%= loginResult %></span>
                <% } else if (loginResult && loginResult.length > 0) { %>
                    <table>
                        <tr><th>ID</th><th>Username</th><th>Role</th></tr>
                        <% loginResult.forEach(r => { %>
                        <tr>
                            <td><%= r.id %></td>
                            <td><%= r.username %></td>
                            <td><span class="badge <%= r.role %>"><%= r.role %></span></td>
                        </tr>
                        <% }) %>
                    </table>
                <% } else { %>
                    <span style="color:#888">Không tìm thấy kết quả</span>
                <% } %>
            </div>
        </div>
        <div></div>
        <% } %>

        <!-- SEARCH DEMO -->
        <div class="section-divider">
            <div class="grid">
                <div class="card danger">
                    <h3>❌ Vulnerable Search</h3>
                    <p class="attack-hint">Thử: <code>' UNION SELECT 1,table_name,3 FROM information_schema.tables# </code></p>
                    <form method="POST" action="/vulnerable/search">
                        <input type="text" name="name" placeholder="Tìm username...">
                        <button type="submit" class="btn-danger">Tìm (Không an toàn)</button>
                    </form>
                </div>

                <div class="card safe">
                    <h3>✅ Secure Search</h3>
                    <p class="attack-hint">Cùng payload sẽ không có tác dụng</p>
                    <form method="POST" action="/vulnerable/secure-search">
                        <input type="text" name="name" placeholder="Tìm username...">
                        <button type="submit" class="btn-safe">Tìm (An toàn)</button>
                    </form>
                </div>
            </div>

            <% if (mode === 'search' || mode === 'secure-search') { %>
            <div style="margin-top:15px">
                <h4>Query thực thi:</h4>
                <div class="query-box"><%= searchQuery %></div>
                <h4>Kết quả:</h4>
                <div class="result-box">
                    <% if (typeof searchResult === 'string') { %>
                        <span style="color:red"><%= searchResult %></span>
                    <% } else if (searchResult && searchResult.length > 0) { %>
                        <table>
                            <tr><th>ID</th><th>Username</th><th>Role</th></tr>
                            <% searchResult.forEach(r => { %>
                            <tr>
                                <td><%= r.id || r.dataValues?.id %></td>
                                <td><%= r.username || r.dataValues?.username %></td>
                                <td><%= r.role || r.dataValues?.role %></td>
                            </tr>
                            <% }) %>
                        </table>
                    <% } else { %>
                        <span style="color:#888">Không tìm thấy kết quả</span>
                    <% } %>
                </div>
            </div>
            <% } %>
        </div>

        <div class="grid" style="margin-top:20px;">
            <div class="card danger">
                <h3>❌ Vulnerable Search by ID</h3>
                <p class="attack-hint">
                    Thử: <code>1 UNION SELECT 1,password_hash,3 FROM users#</code>
                </p>
                <form method="POST" action="/vulnerable/search-by-id">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <input type="text" name="user_id" placeholder="Nhập User ID (1, 2, 3...)">
                    <button type="submit" class="btn-danger">Tìm theo ID (Không an toàn)</button>
                </form>
            </div>

            <div class="card safe">
                <h3>✅ Secure Search by ID</h3>
                <p class="attack-hint">Cùng payload không có tác dụng</p>
                <form method="POST" action="/vulnerable/secure-search-by-id">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <input type="text" name="user_id" placeholder="Nhập User ID">
                    <button type="submit" class="btn-safe">Tìm theo ID (An toàn)</button>
                </form>
            </div>

            <% if (mode === 'id-search' || mode === 'secure-id-search') { %>
            <div class="card" style="<%= mode==='secure-id-search' ? 'border-color:#27ae60' : 'border-color:#e74c3c' %>">
                <h4>Query thực thi:</h4>
                <div class="query-box"><%= idQuery %></div>
                <h4>Kết quả:</h4>
                <div class="result-box">
                    <% if (typeof idResult === 'string') { %>
                        <span style="color:red"><%= idResult %></span>
                    <% } else if (idResult && idResult.length > 0) { %>
                        <table>
                            <tr><th>ID</th><th>Username</th><th>Role / Data</th></tr>
                            <% idResult.forEach(r => { %>
                            <tr>
                                <td><%= r.id ?? r.dataValues?.id %></td>
                                <td><%= r.username ?? r.dataValues?.username %></td>
                                <td><%= r.role ?? r.dataValues?.role %></td>
                            </tr>
                            <% }) %>
                        </table>
                    <% } else { %>
                        <span style="color:#888">Không có kết quả</span>
                    <% } %>
                </div>
            </div>
            <div></div>
            <% } %>
        </div>

        <div class="grid" style="margin-top:20px;">
            <div class="card danger">
                <h3>❌ Time-based Blind Injection</h3>
                <p class="attack-hint">
                    Thử: <code>alice' AND SLEEP(3)#</code> — app sẽ delay ~3 giây<br>
                    So sánh với: <code>alice</code> — trả về ngay lập tức
                </p>
                <form method="POST" action="/vulnerable/blind">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <input type="text" name="payload" placeholder="Nhập username hoặc payload">
                    <button type="submit" class="btn-danger">Kiểm tra (Không an toàn)</button>
                </form>
            </div>
            <div class="card" style="background:#f9f9f9; border-color:#ccc;">
                <h3>ℹ️ Giải thích</h3>
                <p style="font-size:13px; line-height:1.6">
                    Blind Injection không trả về data trực tiếp.<br>
                    Attacker xác nhận lỗ hổng bằng cách đo thời gian phản hồi.<br>
                    <b>SLEEP(3)</b> → server delay 3 giây → injection thành công.<br>
                    Secure endpoint dùng prepared statement → SLEEP() chỉ là string.
                </p>
            </div>

            <% if (mode === 'blind') { %>
            <div class="card danger">
                <h4>Query thực thi:</h4>
                <div class="query-box"><%= blindQuery %></div>
                <h4>Kết quả:</h4>
                <div class="result-box">
                    <span><%= blindResult %></span><br>
                    <span style="color:<%= blindElapsed >= 2000 ? '#e74c3c' : '#27ae60' %>; font-weight:bold;">
                        ⏱ Thời gian phản hồi: <%= blindElapsed %>ms
                        <%= blindElapsed >= 2000 ? '— SLEEP() đã thực thi!' : '— Phản hồi bình thường' %>
                    </span>
                </div>
            </div>
            <div></div>
            <% } %>
        </div>

    </div>
</body>
</html>
